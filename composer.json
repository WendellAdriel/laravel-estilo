{
    "name": "wendelladriel/laravel-estilo",
    "description": "Manage your CSS in PHP and easily use it on Blade",
    "type": "library",
    "keywords": [
        "laravel",
        "css",
        "ui",
        "frontend"
    ],
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "WendellAdriel\\Estilo\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "WendellAdriel\\Estilo\\Tests\\": "tests/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "support": {
        "issues": "https://github.com/WendellAdriel/laravel-estilo/issues",
        "source": "https://github.com/WendellAdriel/laravel-estilo"
    },
    "authors": [
        {
            "name": "Wendell Adriel",
            "email": "wendelladriel.ti@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^12.0|^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.27",
        "orchestra/testbench": "^10.0|^11.0",
        "pestphp/pest": "^3.0|^4.0",
        "phpstan/phpstan": "^2.1"
    },
    "scripts": {
        "lint": "pint --parallel",
        "stan": "phpstan analyse",
        "test:lint": "pint --parallel --test",
        "test:unit": "./vendor/bin/pest --order-by random",
        "test": [
            "@test:lint",
            "@stan",
            "@test:unit"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "WendellAdriel\\Estilo\\Providers\\EstiloServiceProvider"
            ]
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
